# GitHub Personal Access Token (scope: public_repo). Required for live stars/commits/contribution graph.
# Create at https://github.com/settings/tokens — keep server-side only.
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username — used for the contribution graph.
GITHUB_USERNAME=qihongw08

# Riot Games API key — powers the League of Legends card in Hobbies.
# Dev keys expire every 24h: https://developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-here

# Apify API token — only consumed by the weekly scrape-linkedin GitHub
# Action (see .github/workflows/scrape-linkedin.yml). The script uploads
# the raw response to Vercel Blob; runtime reads from Blob, never Apify.
# Set this as a GitHub repo secret.
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your_token_here

# Vercel Blob token. Auto-injected by Vercel when Blob is enabled on the
# project — only needed manually in .env.local to run the scrape script
# locally, and as a GitHub repo secret so the Action can upload.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Public base URL for the `personal-website-content` Vercel Blob store.
# Copy it from any uploaded file's URL (everything up to the pathname),
# e.g. "https://xxxxxxxx.public.blob.vercel-storage.com". Auto-set on
# Vercel deploys if you wire the store to the project; otherwise set it
# in .env.local so `next/image` + `asset()` resolve media correctly.
# When unset, `asset()` falls back to `/<path>` (local public/).
# NEXT_PUBLIC_BLOB_BASE_URL=https://xxxxxxxx.public.blob.vercel-storage.com