# GitHub Personal Access Token (scope: public_repo). Required for live stars/commits/contribution graph.
# Create at https://github.com/settings/tokens — keep server-side only.
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username — used for the contribution graph.
GITHUB_USERNAME=qihongw08

# Riot Games API key — powers the League of Legends card in Hobbies.
# Dev keys expire every 24h: https://developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-here
